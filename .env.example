# API key de OpenAI
OPENAI_API_KEY= 

# API key de Anthropic
ANTHROPIC_API_KEY=

# Router LiteLLM (formato litellm "<proveedor>/<modelo>"):
# modelo por defecto y modelo de fallback. El fallback se usa solo tras fallar
# un reintento de conexión al modelo por defecto.
PRIMARY_MODEL=anthropic/claude-haiku-4-5
FALLBACK_MODEL=openai/gpt-4o-mini

# (Heredados; ya no gobiernan el routing, lo hace el Router LiteLLM)
LLM_PROVIDER=
LLM_MODEL=

# Entorno de ejecución
APP_ENV=

# --- Observabilidad (structlog) ---
# Nivel de logging (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Fuerza salida JSON aunque haya terminal (útil en contenedores/agregadores).
# Por defecto: consola legible con TTY, JSON sin TTY.
LOG_JSON=false

# --- Cache Redis (opcional) ---
# URL de conexión a Redis
REDIS_URL=redis://localhost:6379/0

# Activa/desactiva el cache de estimaciones (true/false)
CACHE_ENABLED=true

# Expiración de las entradas de cache, en segundos (por defecto 24h)
CACHE_TTL_SECONDS=86400