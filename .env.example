# API key de OpenAI
OPENAI_API_KEY= 

# API key de Anthropic
ANTHROPIC_API_KEY=

# Proveedor a utilizar: `openai` o `anthropic`
LLM_PROVIDER=

# Modelo a utilizar
LLM_MODEL=

# Entorno de ejecución
APP_ENV=

# Nivel de logging
LOG_LEVEL=

# --- Cache Redis (opcional) ---
# URL de conexión a Redis
REDIS_URL=redis://localhost:6379/0

# Activa/desactiva el cache de estimaciones (true/false)
CACHE_ENABLED=true

# Expiración de las entradas de cache, en segundos (por defecto 24h)
CACHE_TTL_SECONDS=86400